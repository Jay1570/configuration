[Unit]
Description=Rclone Mount Google Drive 157
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/rclone mount jaygheewala157: /home/jay1570/gdrive157 \
    --vfs-cache-mode writes \
    --buffer-size 256M \
    --dir-cache-time 72h

ExecStop=/bin/fusermount -u /home/jay1570/drive157
Restart=on-failure

[Install]
WantedBy=default.target

[Unit]
Description=Rclone Mount Google Drive 40
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/rclone mount jaygheewala40: /home/jay1570/gdrive40 \
    --vfs-cache-mode writes \
    --buffer-size 256M \
    --dir-cache-time 72h

ExecStop=/bin/fusermount -u /home/jay1570/gdrive40
Restart=on-failure

[Install]
WantedBy=default.target
